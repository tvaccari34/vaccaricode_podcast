---
import Base from "../../layouts/Base.astro";
import PostArticle from "../../components/PostArticle.astro";
import { getPublishedPosts } from "../../lib/db.js";
import { plainExcerpt } from "../../lib/seo.js";

export async function getStaticPaths() {
  const posts = await getPublishedPosts("pt-BR");
  return posts.map((post) => ({ params: { id: post.topic_id }, props: { post } }));
}

const { post } = Astro.props;
const lang = "pt-BR";
const description = plainExcerpt(post.body);
const publishedTime = new Date(post.updated_at).toISOString();
---

<Base title={post.title} lang={lang} alt={`/en/blog/${post.topic_id}`}
      description={description} ogType="article" articleType="BlogPosting" publishedTime={publishedTime}>
  <PostArticle post={post} lang={lang} />
</Base>
