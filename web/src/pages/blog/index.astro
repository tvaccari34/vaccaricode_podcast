---
import Base from "../../layouts/Base.astro";
import PostList from "../../components/PostList.astro";
import ArchiveToc from "../../components/ArchiveToc.astro";
import { STRINGS } from "../../lib/i18n.js";
import { getPublishedPosts } from "../../lib/db.js";
import { groupPostsByMonth } from "../../lib/archive.js";
const lang = "pt-BR";
const t = STRINGS[lang];
const posts = await getPublishedPosts(lang);
const groups = groupPostsByMonth(posts, lang);
---

<Base title={t.nav.blog} lang={lang} alt="/en/blog" description="Posts sobre desenvolvimento de software e tendências de IA.">
  <h1>{t.nav.blog}</h1>
  <div class="archive">
    <PostList groups={groups} lang={lang} />
    <ArchiveToc groups={groups} lang={lang} />
  </div>
</Base>
