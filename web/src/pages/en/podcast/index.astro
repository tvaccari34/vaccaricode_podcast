---
import Base from "../../../layouts/Base.astro";
import EpisodeList from "../../../components/EpisodeList.astro";
import { STRINGS } from "../../../lib/i18n.js";
import { getPublishedEpisodes } from "../../../lib/db.js";
const lang = "en";
const t = STRINGS[lang];
const episodes = await getPublishedEpisodes(lang);
---

<Base title={t.nav.podcast} lang={lang} alt="/podcast" description="Narrated episodes on software and AI trends.">
  <h1>{t.nav.podcast}</h1>
  <p class="muted">{t.podcastIntro}</p>
  <EpisodeList episodes={episodes} lang={lang} />
</Base>
