---
import Base from "../../layouts/Base.astro";
import PostList from "../../components/PostList.astro";
import EpisodeList from "../../components/EpisodeList.astro";
import { STRINGS, href } from "../../lib/i18n.js";
import { getPublishedPosts, getPublishedEpisodes } from "../../lib/db.js";
const lang = "en";
const t = STRINGS[lang];
const posts = await getPublishedPosts(lang);
const episodes = await getPublishedEpisodes(lang);
---

<Base lang={lang} alt="/" description="Automated coverage of trends in software development, AI, and engineering.">
  <section class="hero">
    <h1>{t.heroTitle}</h1>
    <p class="muted">{t.heroBody} <a href={href(lang, "/about")}>Tiago Vaccari</a>.</p>
  </section>
  <h2>{t.latestPosts}</h2>
  <PostList posts={posts} lang={lang} />
  <h2>{t.episodes}</h2>
  <EpisodeList episodes={episodes} lang={lang} />
</Base>
