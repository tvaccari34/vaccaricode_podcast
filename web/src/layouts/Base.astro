---
import "../styles/global.css";
import { STRINGS, href } from "../lib/i18n.js";
import { SITE_NAME, AUTHOR, DEFAULT_OG_IMAGE, OG_LOCALE, canonicalUrl } from "../lib/seo.js";

const {
  title, description, lang = "pt-BR", alt, wide = false,
  // SEO/social: ogType "article" for posts/episodes; articleType + publishedTime feed the JSON-LD.
  ogType = "website", image, articleType, publishedTime,
} = Astro.props;
const t = STRINGS[lang];
const siteName = "Vaccari's Code Podcast";
const fullTitle = title ? `${title} — ${siteName}` : `${siteName} — ${t.tagline}`;
// Where the PT/EN toggle points: the equivalent page if given, else the other language's home.
const otherHome = STRINGS[t.other].base || "/";
const toggleHref = alt || otherHome;
// Strings the client-side search script needs (labels used in attributes stay inline below).
const searchStrings = { empty: t.searchEmpty, error: t.searchError, blog: t.nav.blog, podcast: t.nav.podcast };
// Umami analytics: emitted only when configured (dev/local builds stay clean; unset = kill switch).
const umamiSrc = import.meta.env.PUBLIC_UMAMI_SRC;
const umamiId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;

// ---- SEO / social meta ----
const metaDescription = description || t.siteDescription;
const canonical = canonicalUrl(Astro.url.pathname, Astro.site);
const altUrl = alt ? canonicalUrl(alt, Astro.site) : null;
// PT is the default locale, so x-default points at the PT version of the page.
const xDefault = lang === "pt-BR" ? canonical : altUrl;
const imageUrl = new URL(image || DEFAULT_OG_IMAGE, Astro.site).href;
// X/Twitter attribution handle (e.g. "@tiagovaccari"); site/creator tags emit only when set.
const twitterHandle = import.meta.env.PUBLIC_TWITTER_HANDLE || "";

const person = { "@type": "Person", name: AUTHOR };
const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_NAME,
  url: canonicalUrl(t.base + "/", Astro.site),
  inLanguage: t.htmlLang,
  description: t.siteDescription,
  author: person,
  publisher: person,
};
const articleLd = ogType === "article" ? {
  "@context": "https://schema.org",
  "@type": articleType || "Article",
  headline: title,
  name: title,
  description: metaDescription,
  inLanguage: t.htmlLang,
  datePublished: publishedTime,
  dateModified: publishedTime,
  author: person,
  publisher: person,
  image: imageUrl,
  url: canonical,
  mainEntityOfPage: canonical,
} : null;
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#05060a" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/favicon-180.png" />
    <link rel="alternate" type="application/rss+xml" title="Blog RSS" href={href(lang, "/rss.xml")} />
    <link rel="alternate" type="application/rss+xml" title="Podcast" href={href(lang, "/podcast/feed.xml")} />

    <!-- hreflang: link each page to its other-language equivalent (mirrors the sitemap) -->
    <link rel="alternate" hreflang={t.htmlLang} href={canonical} />
    {altUrl && <link rel="alternate" hreflang={STRINGS[t.other].htmlLang} href={altUrl} />}
    {altUrl && <link rel="alternate" hreflang="x-default" href={xDefault} />}

    <!-- Open Graph: link previews on Facebook, LinkedIn, WhatsApp, Slack, Discord, iMessage -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content={OG_LOCALE[lang]} />
    <meta property="og:locale:alternate" content={OG_LOCALE[t.other]} />
    {ogType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}

    <!-- X/Twitter Card: how the page renders when shared on X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={imageUrl} />
    {twitterHandle && <meta name="twitter:site" content={twitterHandle} />}
    {twitterHandle && <meta name="twitter:creator" content={twitterHandle} />}

    <!-- Structured data for search engines -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    {articleLd && <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />}
    <script is:inline>
      // Neon look is dark-first: default to dark unless the user chose light.
      const saved = localStorage.getItem("theme");
      const theme = saved || "dark";
      document.documentElement.setAttribute("data-theme", theme);
    </script>
    {umamiId && umamiSrc && <script defer src={umamiSrc} data-website-id={umamiId}></script>}
  </head>
  <body>
    <header class="site">
      <div class="wrap">
        <a class="brand" href={t.base || "/"}>
          <img src="/logo-mark.png" alt="" width="30" height="30" />
          <span class="brand-text">Vaccari's <span class="code">Code</span></span>
        </a>
        <nav>
          <a href={href(lang, "/blog")}>{t.nav.blog}</a>
          <a href={href(lang, "/podcast")}>{t.nav.podcast}</a>
          <a href={href(lang, "/about")}>{t.nav.about}</a>
          <a href={href(lang, "/subscribe")}>{t.nav.subscribe}</a>
          <button class="nav-search" id="search-open" aria-label={t.searchLabel}>
            <span aria-hidden="true">🔍</span><span class="nav-search-text">{t.searchLabel}</span>
          </button>
          <a class="langswitch" href={toggleHref} title="Change language">{t.selfLabel}</a>
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">◐</button>
        </nav>
      </div>
    </header>
    <div class="neon-rule"></div>

    <main>
      <div class:list={["wrap", { wide }]}>
        <slot />
      </div>
    </main>

    <footer class="site">
      <div class="wrap">
        © {new Date().getFullYear()} Tiago Vaccari · {t.footer} ·
        <a href={href(lang, "/rss.xml")}>{t.rssLabel}</a> ·
        <a href={href(lang, "/podcast/feed.xml")}>{t.feedLabel}</a>
      </div>
      {umamiId && (
        <div class="wrap" style="opacity:.65;font-size:.82em;margin-top:.35rem">
          {lang === "en"
            ? "Anonymous, cookieless analytics — no personal data or cross-site tracking."
            : "Análise anônima e sem cookies — sem dados pessoais nem rastreamento entre sites."}
        </div>
      )}
    </footer>

    <script is:inline>
      document.getElementById("theme-toggle")?.addEventListener("click", () => {
        const cur = document.documentElement.getAttribute("data-theme") === "light" ? "light" : "dark";
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
      });
    </script>

    <div id="search-modal" class="search-modal" hidden>
      <div class="search-backdrop" data-search-close></div>
      <div class="search-panel" role="dialog" aria-modal="true" aria-label={t.searchLabel}>
        <div class="search-inputrow">
          <span class="search-icon" aria-hidden="true">🔍</span>
          <input id="search-input" type="search" autocomplete="off" spellcheck="false"
                 placeholder={t.searchPlaceholder} aria-label={t.searchLabel} />
          <button class="search-close" data-search-close aria-label={t.searchClose}>Esc</button>
        </div>
        <div id="search-results" class="search-results" aria-live="polite"></div>
      </div>
    </div>

    <script define:vars={{ S: searchStrings }}>
      (function () {
        const modal = document.getElementById("search-modal");
        const input = document.getElementById("search-input");
        const results = document.getElementById("search-results");
        const openBtn = document.getElementById("search-open");
        if (!modal || !input || !results) return;
        let pagefind = null, loaded = false, lastFocus = null, debounce;

        async function ensurePagefind() {
          if (loaded) return pagefind;
          loaded = true;
          try {
            // The /pagefind/ bundle is generated after `astro build`, so it must not be
            // resolved by Vite at build time — load it at runtime.
            pagefind = await import(/* @vite-ignore */ "/pagefind/pagefind.js");
            await pagefind.init();
          } catch (e) {
            pagefind = null;
          }
          return pagefind;
        }
        function esc(s) { const d = document.createElement("div"); d.textContent = s || ""; return d.innerHTML; }
        function typeLabel(t) { return t === "podcast" ? S.podcast : S.blog; }

        function open() {
          lastFocus = document.activeElement;
          modal.hidden = false;
          document.body.style.overflow = "hidden";
          input.focus();
          ensurePagefind();
        }
        function close() {
          modal.hidden = true;
          document.body.style.overflow = "";
          input.value = ""; results.innerHTML = "";
          if (lastFocus && lastFocus.focus) lastFocus.focus();
        }

        async function run(q) {
          const pf = await ensurePagefind();
          if (!pf) { results.innerHTML = '<p class="search-msg">' + esc(S.error) + "</p>"; return; }
          if (!q.trim()) { results.innerHTML = ""; return; }
          const search = await pf.search(q);
          const items = await Promise.all(search.results.slice(0, 8).map((r) => r.data()));
          if (!items.length) { results.innerHTML = '<p class="search-msg">' + esc(S.empty) + "</p>"; return; }
          results.innerHTML = items.map(function (d) {
            const type = (d.meta && d.meta.type) || "blog";
            const title = (d.meta && d.meta.title) || d.url;
            return '<a class="search-hit" href="' + d.url + '">' +
              '<span class="search-hit-tag" data-type="' + esc(type) + '">' + esc(typeLabel(type)) + "</span>" +
              '<span class="search-hit-title">' + esc(title) + "</span>" +
              '<span class="search-hit-excerpt">' + d.excerpt + "</span>" +
              "</a>";
          }).join("");
        }

        if (openBtn) openBtn.addEventListener("click", open);
        document.addEventListener("keydown", function (e) {
          if ((e.ctrlKey || e.metaKey) && (e.key === "k" || e.key === "K")) {
            e.preventDefault(); modal.hidden ? open() : close();
          } else if (e.key === "Escape" && !modal.hidden) { close(); }
        });
        modal.querySelectorAll("[data-search-close]").forEach(function (el) {
          el.addEventListener("click", close);
        });
        input.addEventListener("input", function () {
          clearTimeout(debounce);
          const q = input.value;
          debounce = setTimeout(function () { run(q); }, 180);
        });
      })();
    </script>
  </body>
</html>
