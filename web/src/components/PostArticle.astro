---
import { safeMatter } from "../lib/frontmatter.js";
import { renderMarkdown } from "../lib/markdown.js";
import { STRINGS, href } from "../lib/i18n.js";
const { post, lang } = Astro.props;
const t = STRINGS[lang];
const parsed = safeMatter(post.body);
const html = renderMarkdown(parsed.content);
const title = parsed.data.title || post.title;
const dateStr = parsed.data.date
  ? new Date(parsed.data.date).toLocaleDateString()
  : new Date(post.updated_at).toLocaleDateString();
---
<article data-pagefind-body data-pagefind-meta="type:blog">
  <h1>{title}</h1>
  <p class="meta">{dateStr}</p>
  <div set:html={html} />
</article>
<p style="margin-top:2rem">
  <a href={href(lang, "/blog")}>{t.allPosts}</a> ·
  <a href={href(lang, `/podcast/${post.topic_id}`)}>{t.listenEpisode}</a>
</p>
