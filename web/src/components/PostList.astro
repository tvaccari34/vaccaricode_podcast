---
import { STRINGS } from "../lib/i18n.js";
import PostCard from "./PostCard.astro";
// `groups` (month buckets) → grouped archive listing; otherwise a flat list from `posts`.
const { posts, groups, lang } = Astro.props;
const t = STRINGS[lang];
---
{groups ? (
  groups.length === 0 ? (
    <p class="muted">{t.noPosts}</p>
  ) : (
    <div class="post-groups">
      {groups.map((g) => (
        <section class="month-group">
          <h2 id={g.anchorId} class="month-heading">{g.label}</h2>
          <ul class="bare">
            {g.posts.map((p) => (
              <PostCard post={p} lang={lang} />
            ))}
          </ul>
        </section>
      ))}
    </div>
  )
) : (
  <>
    {posts.length === 0 && <p class="muted">{t.noPosts}</p>}
    <ul class="bare">
      {posts.map((p) => (
        <PostCard post={p} lang={lang} />
      ))}
    </ul>
  </>
)}
