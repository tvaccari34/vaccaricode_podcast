---
import { safeMatter } from "../lib/frontmatter.js";
import { STRINGS, href } from "../lib/i18n.js";
// `groups` (month buckets) → grouped archive listing; otherwise a flat list from `posts`.
const { posts, groups, lang } = Astro.props;
const t = STRINGS[lang];
function excerpt(body) {
  const { content } = safeMatter(body);
  const p = content.trim().split("\n\n").find((x) => x.trim() && !x.startsWith("#")) || "";
  return p.replace(/[#*`>]/g, "").slice(0, 200);
}
---
{groups ? (
  groups.length === 0 ? (
    <p class="muted">{t.noPosts}</p>
  ) : (
    <div class="post-groups">
      {groups.map((g) => (
        <section class="month-group">
          <h2 id={g.anchorId} class="month-heading">{g.label}</h2>
          <ul class="bare">
            {g.posts.map((p) => (
              <li class="card">
                <h3><a href={href(lang, `/blog/${p.topic_id}`)}>{p.title}</a></h3>
                <p class="meta">{new Date(p.updated_at).toLocaleDateString()}</p>
                <p>{excerpt(p.body)}…</p>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  )
) : (
  <>
    {posts.length === 0 && <p class="muted">{t.noPosts}</p>}
    <ul class="bare">
      {posts.map((p) => (
        <li class="card">
          <h3><a href={href(lang, `/blog/${p.topic_id}`)}>{p.title}</a></h3>
          <p class="meta">{new Date(p.updated_at).toLocaleDateString()}</p>
          <p>{excerpt(p.body)}…</p>
        </li>
      ))}
    </ul>
  </>
)}
