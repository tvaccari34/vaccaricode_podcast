# ──────────────────────────────────────────────────────────────────────────
# boosternews environment. Copy to `.env` and fill in. NEVER commit `.env`.
# Required values have no safe default; the app fails fast if they are missing.
# ──────────────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────────────
SITE_DOMAIN=tiagovaccari.com

# ── PostgreSQL (app database) ─────────────────────────────────────────────
POSTGRES_USER=boosternews
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=boosternews
# Used by the pipeline (host `postgres` is the compose service name):
DATABASE_URL=postgresql://boosternews:change-me-strong@postgres:5432/boosternews

# Listmonk uses its own database on the same Postgres instance:
LISTMONK_DB=listmonk

# ── Object storage (MinIO in dev; any S3-compatible store in prod) ─────────
MINIO_ROOT_USER=boosternews
MINIO_ROOT_PASSWORD=change-me-strong
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=boosternews
S3_SECRET_ACCESS_KEY=change-me-strong
S3_BUCKET_AUDIO=boosternews-audio
# Public base URL used to build audio enclosure links in the podcast feed:
S3_PUBLIC_BASE_URL=https://tiagovaccari.com/audio

# ── Google Gemini ─────────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── Review dashboard auth (HTTP Basic) ────────────────────────────────────
# REQUIRED to protect the dashboard. If DASHBOARD_PASSWORD is empty, auth is disabled (dev only).
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me-strong
# Caddy fronts the dashboard on its own origin with Basic Auth (a 2nd layer on top of the app's).
# Dev: http://dashboard.localhost (plain HTTP). Prod: a bare subdomain → automatic HTTPS.
# The bcrypt hash of DASHBOARD_PASSWORD is stored in deploy/caddy/Caddyfile — regenerate it with
#   docker run --rm caddy:2 caddy hash-password --plaintext 'your-password'
# and keep DASHBOARD_USER in sync (Caddy checks the username; the app checks user+password).
DASHBOARD_DOMAIN=dashboard.tiagovaccari.com

# ── Home sound-worker auth ────────────────────────────────────────────────
# Shared bearer token the home worker uses to claim narration jobs from the VPS.
WORKER_AUTH_TOKEN=change-me-long-random

# ── Sound-worker (set these on the HOME machine's .env) ───────────────────
# Base URL of the VPS narration API, reachable from home over HTTPS:
VPS_API_URL=https://tiagovaccari.com/api
WORKER_ID=home-4060ti
VOICE_ID=tiago

# ── Newsletter SMTP (pluggable: amazon_ses | resend) ──────────────────────
# Listmonk holds named SMTP configs; switch the active provider in its admin UI.
SMTP_PROVIDER=amazon_ses
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=news@tiagovaccari.com
